# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# ── Bybit API ─────────────────────────────────────────────────────────────────
# Create at: bybit.com → Account → API Management
# Required permissions: Read + Trade (P2P)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Use 'true' to hit testnet instead of mainnet
BYBIT_TESTNET=false
# ── Admin ──────────────────────────────────────────────────────────────────
# Your Telegram user ID for admin actions in the bot
ADMIN_TELEGRAM_ID=123456789
# ── Mini App ──────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (set after first deploy)
MINI_APP_URL=https://your-project.vercel.app
