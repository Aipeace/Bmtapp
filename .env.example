# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# ── Bybit API ─────────────────────────────────────────────────────────────────
# Create at: bybit.com → Account → API Management
# Required permissions: Read + Trade (P2P)
# NOTE: For the multi-user server.js deployment, these are NOT needed here —
#       each user supplies their own keys via /setup in the bot.
#       They ARE needed only for the single-user api/index.js (Vercel) deployment.
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Use 'true' to hit testnet instead of mainnet
BYBIT_TESTNET=false

# ── Admin ─────────────────────────────────────────────────────────────────────
# Your personal Telegram user ID — grants access to admin commands in the bot
ADMIN_TELEGRAM_ID=123456789

# ── Security ──────────────────────────────────────────────────────────────────
# 32-character secret used to AES-encrypt stored API secrets.
# CHANGE THIS before first deploy. Any string is fine — make it random.
APP_SECRET=change_me_32_chars_exactly!!!!!!

# ── Mini App ──────────────────────────────────────────────────────────────────
# Your Render/Vercel deployment URL (set after first deploy)
MINI_APP_URL=https://your-project.onrender.com

# ── Environment ───────────────────────────────────────────────────────────────
# Set to 'development' locally to enable x-dev-user-id bypass header
NODE_ENV=production
